# ─────────────────────────────────────────────
# LLM Provider API Keys
# Get these from each provider's dashboard
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ─────────────────────────────────────────────
# Redis (used for caching + cost tracking)
# Default: local Redis on standard port
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Semantic Cache Settings
# similarity_threshold: 0.0–1.0, higher = stricter match required
# ttl_seconds: how long a cached response lives before expiring
# ─────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_SECONDS=3600

# ─────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────
APP_ENV=development   # development | production
LOG_LEVEL=INFO
